---

<section class="py-24 bg-[#0F0F0F]">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Título e subtítulo -->
    <div class="text-center mb-12 animate-on-scroll">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-4">
        Garantia Incondicional de <span class="gradient-orange">7 Dias</span>
      </h2>
      <p class="text-[#A0A0A0] text-lg">Sua satisfação é nossa prioridade absoluta</p>
    </div>
    
    <!-- Descrição -->
    <div class="max-w-3xl mx-auto mb-16 animate-on-scroll">
      <p class="text-[#A0A0A0] text-lg leading-relaxed text-center">
        Experimente a comunidade por 7 dias completos. Se por qualquer motivo você não estiver satisfeito, devolvemos 100% do seu investimento sem questionamentos.
      </p>
    </div>
    
    <!-- Três colunas -->
    <div class="grid sm:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16 animate-on-scroll">
      <div class="text-center p-6 glass-card rounded-none card-hover">
        <div class="w-16 h-16 mx-auto mb-4  bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center shadow-[0_0_20px_rgba(255,107,0,0.3)]">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-[700] text-white mb-2">Sem Burocracia</h3>
        <p class="text-[#A0A0A0] text-sm">Processo descomplicado e rápido</p>
      </div>
      
      <div class="text-center p-6 glass-card rounded-none card-hover">
        <div class="w-16 h-16 mx-auto mb-4  bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center shadow-[0_0_20px_rgba(255,107,0,0.3)]">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-[700] text-white mb-2">7 Dias Completos</h3>
        <p class="text-[#A0A0A0] text-sm">Tempo suficiente para decidir</p>
      </div>
      
      <div class="text-center p-6 glass-card rounded-none card-hover">
        <div class="w-16 h-16 mx-auto mb-4  bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center shadow-[0_0_20px_rgba(255,107,0,0.3)]">
          <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-lg font-[700] text-white mb-2">Reembolso Total</h3>
        <p class="text-[#A0A0A0] text-sm">100% do valor devolvido</p>
      </div>
    </div>
    
    <!-- Contatos para reembolso -->
    <div class="glass-card rounded-none p-8 max-w-2xl mx-auto mb-12 animate-on-scroll">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a href="mailto:script7sistemas@gmail.com" class="flex items-center gap-3 group">
