    </div>
    
    <!-- Quote final -->
    <div class="text-center animate-on-scroll">
      <blockquote class="max-w-2xl mx-auto">
        <p class="text-xl lg:text-2xl font-[700] text-white italic mb-4">
          "Acreditamos tanto no valor da nossa comunidade que assumimos todo o risco por você"
        </p>
      </blockquote>
    </div>
  </div>
</section>
