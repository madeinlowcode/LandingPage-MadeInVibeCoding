<section id="comunidade" class="py-24 bg-black-section">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Badge superior -->
    <div class="text-center mb-12 animate-on-scroll">
      <span class="font-mono text-xs text-orange-brand uppercase tracking-widest bg-[rgba(255,107,0,0.1)] px-4 py-2  border border-[rgba(255,107,0,0.2)]">
        MADEINVIBECODING
      </span>
    </div>
    
    <!-- Titulo e descricao -->
    <div class="text-center max-w-4xl mx-auto mb-16 animate-on-scroll">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6">
        O que acontece na <span class="gradient-orange">Made In Vibe Coding</span>
      </h2>
      <p class="text-secondary text-lg lg:text-xl leading-relaxed">
        A Made In Vibe Coding nao e mais um curso. Somos a sua plataforma estrategica para dominar o desenvolvimento de software com Inteligencia Artificial de forma profissional e sustentavel.
      </p>
    </div>
    
    <!-- Grid de 8 cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 animate-on-scroll">
      {features.map((feature) => (
        <div class="glass-card rounded-none p-6 card-hover group">
          <div class="w-12 h-12 rounded-none bg-gradient-to-br from-orange-brand to-orange-light flex items-center justify-center mb-4 shadow-[0_0_20px_rgba(255,107,0,0.3)] group-hover:shadow-[0_0_30px_rgba(255,107,0,0.5)] transition-all duration-300 text-white">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={feature.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-extrabold text-white mb-3">{feature.title}</h3>
          <p class="text-secondary text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
