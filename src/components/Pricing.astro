---
---

<section id="planos" class="py-24 bg-black-card relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-orange-brand opacity-5 blur-[150px]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <!-- Badge superior -->
    <div class="text-center mb-12 animate-on-scroll">
      <span class="badge badge-orange">
        🔥 Oferta Exclusiva
      </span>
    </div>

    <!-- Título e subtítulo -->
    <div class="text-center max-w-4xl mx-auto mb-16 animate-on-scroll">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6">
        Selecione um plano e tenha acesso completo à plataforma
      </h2>
      <p class="text-secondary text-lg leading-relaxed">
        Junte-se à elite de desenvolvedores que estão dominando IA e multiplicando seus resultados.
      </p>
    </div>

    <!-- Cards de planos -->
    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto mb-16 animate-on-scroll">
      <!-- PLANO MENSAL -->
      <div class="glass-card p-8 relative overflow-hidden card-hover group">
        <div class="relative">
          <!-- Título -->
          <div class="mb-6">
            <h3 class="text-2xl font-bold text-white mb-2">Mensal</h3>
            <p class="text-secondary text-sm">Acesso mensal a todos os cursos e recursos</p>
          </div>

          <!-- Preço -->
          <div class="mb-6">
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-extrabold text-white">R$ 139,00</span>
              <span class="text-secondary text-sm">/mês</span>
            </div>
          </div>

          <!-- Benefícios -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Acesso a todos os cursos</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Novos cursos toda semana</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Comunidade exclusiva</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Certificados de conclusão</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Suporte prioritário</span>
            </li>
          </ul>

          <!-- Botão -->
          <a href="https://plataforma.madeinvibecoding.com/register" target="_blank" class="btn-primary w-full flex items-center justify-center gap-2 px-6 py-4 text-white font-semibold">
            Assinar
          </a>
        </div>
      </div>

      <!-- PLANO ANUAL -->
      <div class="glass-card p-8 relative overflow-hidden card-hover group border-orange-brand/30">
        <!-- Badge Economia -->
        <div class="absolute top-0 right-0 bg-green-500/20 border border-green-500/30 px-4 py-2">
          <span class="text-green-500 font-mono text-xs font-semibold">Economia de 20%</span>
        </div>

        <div class="relative">
          <!-- Título -->
          <div class="mb-6">
            <h3 class="text-2xl font-bold text-white mb-2">Anual</h3>
            <p class="text-secondary text-sm">Acesso anual com economia de R$ 1.069,20</p>
          </div>

          <!-- Preço -->
          <div class="mb-6">
            <div class="flex items-baseline gap-2">
              <span class="text-4xl font-extrabold text-white">R$ 598,80</span>
              <span class="text-secondary text-sm">/ano</span>
            </div>
          </div>

          <!-- Benefícios -->
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Tudo do plano Mensal</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Economia de 64%</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Acesso por 12 meses</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Cursos bônus exclusivos</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Mentoria em grupo mensal</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-green-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="text-secondary">Downloads ilimitados</span>
            </li>
          </ul>

          <!-- Botão -->
          <a href="https://plataforma.madeinvibecoding.com/register" target="_blank" class="btn-primary w-full flex items-center justify-center gap-2 px-6 py-4 text-white font-semibold">
            Assinar
          </a>
        </div>
      </div>
    </div>

    <!-- Garantia -->
    <div class="glass-card rounded-none p-8 max-w-3xl mx-auto animate-on-scroll">
      <div class="flex flex-col md:flex-row items-center gap-6">
        <div class="w-20 h-20 rounded-none bg-gradient-to-br from-orange-brand to-orange-light flex items-center justify-center flex-shrink-0">
          <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div class="text-center md:text-left">
          <h3 class="text-xl font-bold text-white mb-2">Garantia de 7 dias</h3>
          <p class="text-secondary text-sm">
            Se não estiver satisfeito, devolvemos 100% do seu dinheiro. Sem perguntas, sem burocracia.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
