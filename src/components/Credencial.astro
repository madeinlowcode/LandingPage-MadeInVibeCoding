---
---

<section class="py-24 bg-[#0F0F0F] relative overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#FF6B00] opacity-5 blur-[150px] "></div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 relative z-10">
    <div class="text-center mb-12 animate-on-scroll">
      <!-- Badge -->
      <span class="font-mono text-xs text-[#FF6B00] uppercase tracking-widest bg-[rgba(255,107,0,0.1)] px-4 py-2  border border-[rgba(255,107,0,0.2)]">
        🎫 SEU ACESSO EXCLUSIVO
      </span>
    </div>
    
    <!-- Título e descrição -->
    <div class="text-center max-w-3xl mx-auto mb-12 animate-on-scroll">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6">
        Garanta Sua <span class="gradient-orange">Credencial</span> na Made In Vibe Coding
      </h2>
      <p class="text-[#A0A0A0] text-lg lg:text-xl leading-relaxed">
        Mais do que um curso - é sua credencial de acesso VIP para uma comunidade exclusiva de desenvolvedores que dominam IA em produção.
      </p>
    </div>
    
    <!-- Badge/Credencial 3D interativa -->
    <div class="flex justify-center mb-12 animate-on-scroll">
      <div class="credential-card relative group cursor-pointer" style="perspective: 1000px;">
        <div class="relative w-80 h-48 sm:w-96 sm:h-56 transition-transform duration-500 transform-style-preserve-3d group-hover:rotate-y-180">
          <!-- Frente -->
          <div class="absolute inset-0 glass-card rounded-none p-8 backface-hidden overflow-hidden">
            <!-- Glow effect -->
            <div class="absolute -top-20 -right-20 w-40 h-40 bg-[#FF6B00] opacity-20 blur-[60px]"></div>
            <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-[#FF8C3A] opacity-20 blur-[60px]"></div>
            
            <!-- Conteúdo -->
            <div class="relative h-full flex flex-col justify-between">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-none bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center shadow-[0_0_20px_rgba(255,107,0,0.4)]">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                    </svg>
                  </div>
                  <span class="font-[Syne] font-bold text-white text-sm">MADE IN VIBE CODING</span>
                </div>
                <div class="w-3 h-3 bg-green-500  animate-pulse"></div>
              </div>
              
              <div class="text-center">
                <p class="font-mono text-xs text-[#FF6B00] uppercase tracking-widest mb-2">Membro Fundador</p>
                <p class="font-[Syne] font-bold text-2xl text-white">ACESSO VITALÍCIO</p>
              </div>
              
              <div class="flex items-center justify-between">
                <div class="font-mono text-xs text-[#A0A0A0]">ID: #FOUNDERS-2025</div>
                <div class="flex items-center gap-1">
                  <div class="w-8 h-8  bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center">
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                    </svg>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Scan line -->
            <div class="absolute inset-0 scan-line-credential"></div>
          </div>
          
          <!-- Verso -->
          <div class="absolute inset-0 glass-card rounded-none p-8 backface-hidden rotate-y-180 overflow-hidden">
            <!-- Glow effect -->
            <div class="absolute -top-20 -right-20 w-40 h-40 bg-[#FF6B00] opacity-20 blur-[60px]"></div>
            
            <!-- Conteúdo -->
            <div class="relative h-full flex flex-col justify-center items-center text-center">
              <div class="w-16 h-16 rounded-none bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center mb-4 shadow-[0_0_30px_rgba(255,107,0,0.4)]">
                <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
                </svg>
              </div>
              <p class="font-[Syne] font-bold text-white text-lg mb-2">Acesso Garantido</p>
              <p class="font-mono text-xs text-[#A0A0A0]">Comunidade Elite de Desenvolvedores</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- CTA central -->
    <div class="text-center animate-on-scroll">
      <a href="#planos" class="btn-primary inline-flex items-center gap-3 px-10 py-5  text-white font-semibold text-lg">
        Quero Minha Credencial Agora
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .transform-style-preserve-3d {
    transform-style: preserve-3d;
  }
  
  .backface-hidden {
    backface-visibility: hidden;
  }
  
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  
  @keyframes scan-line-credential {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }
  
  .scan-line-credential::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, rgba(255, 107, 0, 0.1), transparent);
    animation: scan-line-credential 3s linear infinite;
    pointer-events: none;
  }
</style>
