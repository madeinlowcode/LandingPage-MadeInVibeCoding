---
---

<section class="py-24 bg-[#0F0F0F]">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Badge superior -->
    <div class="text-center mb-12 animate-on-scroll">
      <span class="font-mono text-xs text-[#FF6B00] uppercase tracking-widest bg-[rgba(255,107,0,0.1)] px-4 py-2  border border-[rgba(255,107,0,0.2)]">
        Detecção de Tendências
      </span>
    </div>
    
    <!-- Título e descrição -->
    <div class="text-center max-w-4xl mx-auto mb-16 animate-on-scroll">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6">
        Antecipe o <span class="gradient-orange">futuro da IA</span> antes dos outros
      </h2>
      <p class="text-[#A0A0A0] text-lg lg:text-xl leading-relaxed">
        Filtramos o ruído do mercado, validamos ferramentas em produção e mapeamos apenas as tecnologias que entregam resultados concretos. Economize tempo e recursos focando no que realmente funciona.
        <br /><br />
        <span class="text-white font-medium">Enquanto a maioria corre atrás de modas passageiras, você estará à frente identificando as verdadeiras oportunidades.</span>
      </p>
    </div>
    
    <!-- Cards lado a lado -->
    <div class="grid md:grid-cols-2 gap-8 mb-16 animate-on-scroll">
      <!-- Card 1 -->
      <div class="glass-card rounded-none p-8 card-hover group">
        <div class="w-14 h-14 rounded-none bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(255,107,0,0.3)] group-hover:shadow-[0_0_30px_rgba(255,107,0,0.5)] transition-all duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-[700] text-white mb-4">Visão Estratégica</h3>
        <p class="text-[#A0A0A0] leading-relaxed">
          Enxergue além do hype e identifique tecnologias com potencial real de transformação. Nossa curadoria elimina o ruído e foca no que traz resultados mensuráveis.
        </p>
      </div>
      
      <!-- Card 2 -->
      <div class="glass-card rounded-none p-8 card-hover group">
        <div class="w-14 h-14 rounded-none bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A] flex items-center justify-center mb-6 shadow-[0_0_20px_rgba(255,107,0,0.3)] group-hover:shadow-[0_0_30px_rgba(255,107,0,0.5)] transition-all duration-300">
          <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-2xl font-[700] text-white mb-4">Aplicação Prática</h3>
        <p class="text-[#A0A0A0] leading-relaxed">
          Validamos cada ferramenta em cenários reais de produção, não em demos artificiais. Você aprende o que funciona na prática, com casos de uso reais e testados.
        </p>
      </div>
    </div>
    
    <!-- Elemento visual: Radar de Oportunidades -->
    <div class="animate-on-scroll">
      <div class="glass-card rounded-none p-8 lg:p-12 relative overflow-hidden">
        <!-- Radar visual -->
        <div class="relative max-w-3xl mx-auto">
          <!-- Radar circles -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-64 h-64  border border-[rgba(255,107,0,0.2)]"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-48 h-48  border border-[rgba(255,107,0,0.3)]"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-32 h-32  border border-[rgba(255,107,0,0.4)]"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-16 h-16  border border-[rgba(255,107,0,0.5)]"></div>
          </div>
          
          <!-- Radar sweep -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="radar-sweep w-64 h-64"></div>
          </div>
          
          <!-- Dots -->
          <div class="absolute top-1/4 left-1/4 w-3 h-3 bg-[#FF6B00]  shadow-[0_0_15px_#FF6B00] animate-pulse"></div>
          <div class="absolute top-1/3 right-1/4 w-3 h-3 bg-[#FF8C3A]  shadow-[0_0_15px_#FF8C3A] animate-pulse" style="animation-delay: 0.5s;"></div>
          <div class="absolute bottom-1/4 left-1/3 w-3 h-3 bg-[#FF6B00]  shadow-[0_0_15px_#FF6B00] animate-pulse" style="animation-delay: 1s;"></div>
          <div class="absolute bottom-1/3 right-1/3 w-3 h-3 bg-[#FF8C3A]  shadow-[0_0_15px_#FF8C3A] animate-pulse" style="animation-delay: 1.5s;"></div>
          
          <!-- Center -->
          <div class="relative flex items-center justify-center pt-40 pb-8">
            <div class="w-8 h-8 bg-gradient-to-br from-[#FF6B00] to-[#FF8C3A]  shadow-[0_0_30px_rgba(255,107,0,0.6)]"></div>
          </div>
        </div>
        
        <!-- Labels -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 text-center">
          <div class="p-4 rounded-none bg-[rgba(255,107,0,0.1)] border border-[rgba(255,107,0,0.2)]">
            <p class="font-mono text-xs text-[#FF6B00] mb-1">EMERGENTE</p>
            <p class="text-white font-semibold text-sm">Agentes AI</p>
          </div>
          <div class="p-4 rounded-none bg-[rgba(255,107,0,0.1)] border border-[rgba(255,107,0,0.2)]">
            <p class="font-mono text-xs text-[#FF6B00] mb-1">TENDÊNCIA</p>
            <p class="text-white font-semibold text-sm">Code Generation</p>
          </div>
          <div class="p-4 rounded-none bg-[rgba(255,107,0,0.1)] border border-[rgba(255,107,0,0.2)]">
            <p class="font-mono text-xs text-[#FF6B00] mb-1">CONSOLIDADO</p>
            <p class="text-white font-semibold text-sm">Low-Code</p>
          </div>
          <div class="p-4 rounded-none bg-[rgba(255,107,0,0.1)] border border-[rgba(255,107,0,0.2)]">
            <p class="font-mono text-xs text-[#FF6B00] mb-1">OPORTUNIDADE</p>
            <p class="text-white font-semibold text-sm">Automation</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes radar-sweep {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  
  .radar-sweep {
    background: conic-gradient(from 0deg, transparent 0deg, rgba(255, 107, 0, 0.1) 60deg, rgba(255, 107, 0, 0.3) 90deg, transparent 91deg);
    animation: radar-sweep 4s linear infinite;
  }
</style>
