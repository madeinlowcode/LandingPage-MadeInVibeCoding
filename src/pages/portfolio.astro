---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "MegaAPI",
    description: "A solução definitiva para integrar o WhatsApp ao seu negócio. API robusta e escalável que automatiza conversas, escala atendimentos e aumenta conversões. Com 10k+ usuários ativos, 99.9% de uptime e suporte 24/7.",
    image: "/images/portfolio/megaapi.png",
    technologies: ["TypeScript", "PHP", "PostgreSQL", "Claude Code"],
    link: "https://megaapi.io",
    featured: true
  },
  {
    title: "Nano Thumb",
    description: "Gerador de thumbnails virais para YouTube com IA. Transforme suas ideias em thumbnails profissionais usando Google Nano Banana Pro e Replicate. Interface gratuita com modelo BYOK, personas e title overlay.",
    image: "/images/portfolio/nanothumb.png",
    technologies: ["Astro.js", "Nano Banana Pro", "Replicate", "Claude Code"],
    link: "https://nanothumb.madeinvibecoding.com",
    featured: true
  },
  {
    title: "myPDF.AI",
    description: "Extraia dados de PDFs com facilidade absoluta. IA que processa desde PDFs simples de 1 página até documentos complexos de mais de 1000 páginas com a mesma precisão. Suporte a RAG com modelos da Mistral, Google, Anthropic e OpenAI.",
    image: "/images/portfolio/mypdf.png",
    technologies: ["React", "Next.js", "Mistral", "Claude Code"],
    link: "https://mypdf-ai.com/",
    featured: true
  },
  {
    title: "LocalAPI",
    description: "Dados de qualquer negócio local em uma chamada de 2 segundos. API REST que extrai nome, telefone, reviews, horários, Popular Times e redes sociais de qualquer empresa no Google Maps. 50 buscas grátis, sem cartão.",
    image: "/images/portfolio/localapi.png",
    technologies: ["Python", "Next.js", "Astro.js", "Redis", "Docker"],
    link: "https://local-api.com/",
    featured: true
  },
  {
    title: "Script7 E-commerce",
    description: "Plataforma completa de e-commerce com carrinho de compras, integração de pagamentos, gestão de estoque e painel administrativo.",
    image: "/images/portfolio/ecommerce.png",
    technologies: ["Next.js", "React", "Node.js", "PostgreSQL", "Stripe"],
    link: "#",
    featured: false
  },
  {
    title: "DevTasks Pro",
    description: "Aplicativo de gestão de tarefas para desenvolvedores com integração ao GitHub, tracking de tempo e relatórios de produtividade.",
    image: "/images/portfolio/devtasks.png",
    technologies: ["Vue.js", "Firebase", "TailwindCSS", "GitHub API"],
    link: "#",
    featured: false
  },
  {
    title: "AI Code Assistant",
    description: "Extensão para VS Code que utiliza IA para sugerir snippets de código, refatorações e correções em tempo real.",
    image: "/images/portfolio/aicode.png",
    technologies: ["TypeScript", "Node.js", "OpenAI API", "VS Code API"],
    link: "#",
    featured: false
  },
  {
    title: "Finance Dashboard",
    description: "Dashboard financeiro para pequenas empresas com controle de fluxo de caixa, DRE e relatórios gerenciais automatizados.",
    image: "/images/portfolio/finance.png",
    technologies: ["React", "D3.js", "Node.js", "MongoDB", "Chart.js"],
    link: "#",
    featured: false
  }
];
---

<Layout
  title="Portfólio - Made In Vibe Coding"
  description="Confira os projetos desenvolvidos pela Made In Vibe Coding. Soluções inovadoras com IA e desenvolvimento de software."
>
  <div class="min-h-screen bg-black-base pt-32" style="padding-bottom: 10rem;">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Header -->
      <div class="mb-20 animate-on-scroll">
        <!-- Navegação de volta -->
        <a href="/" class="portfolio-back-link inline-flex items-center gap-2 text-secondary hover:text-orange-brand mb-12 text-sm font-medium transition-colors duration-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Voltar ao inicio
        </a>

        <div class="text-center">
          <span class="badge badge-orange mb-6 inline-block">Meus Projetos</span>
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6">
            Portfolio <span class="gradient-orange">Made In Vibe Coding</span>
          </h1>
          <p class="text-secondary text-lg max-w-2xl mx-auto leading-relaxed">
            Projetos reais desenvolvidos com as melhores praticas do mercado,
            pensando em performance, escalabilidade e experiencia do usuario.
          </p>
        </div>
      </div>

      <!-- Projetos em Destaque -->
      <div class="animate-on-scroll" style="margin-bottom: 6rem;">
        <div class="flex items-center gap-3 mb-10">
          <div class="w-8 h-[2px] bg-orange-brand"></div>
          <h2 class="text-xl font-bold text-white uppercase tracking-wider">Destaques</h2>
        </div>
        <div class="grid lg:grid-cols-2" style="gap: 3rem;">
          {projects.filter(p => p.featured).map((project) => (
            <div class="portfolio-featured-card group">
              <div class="relative h-56 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-[#080808] via-transparent to-transparent z-10"></div>
                <img
                  src={project.image}
                  alt={`Screenshot do projeto ${project.title} - ${project.description.substring(0, 60)}`}
                  width="600"
                  height="224"
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect fill=%22%23111%22 width=%22400%22 height=%22300%22/%3E%3Ctext fill=%22%23444%22 x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 font-family=%22monospace%22 dy=%22.3em%22%3EProjeto%3C/text%3E%3C/svg%3E'"
                />
              </div>
              <div class="p-8">
                <h3 class="text-2xl font-bold text-white mb-3">{project.title}</h3>
                <p class="text-secondary mb-6 leading-relaxed text-[15px]">{project.description}</p>
                <div class="flex flex-wrap gap-2 mb-8">
                  {project.technologies.map((tech) => (
                    <span class="portfolio-tech-tag">{tech}</span>
                  ))}
                </div>
                <a
                  href={project.link}
                  target="_blank"
                  class="btn-primary inline-flex items-center gap-2 px-6 py-3 text-white font-semibold text-sm"
                >
                  Acessar Projeto
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Todos os Projetos -->
      <div class="animate-on-scroll">
        <div class="flex items-center gap-3 mb-10">
          <div class="w-8 h-[2px] bg-orange-brand"></div>
          <h2 class="text-xl font-bold text-white uppercase tracking-wider">Todos os Projetos</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3" style="gap: 2rem;">
          {projects.filter(p => !p.featured).map((project) => (
            <div class="portfolio-card group">
              <div class="relative h-44 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0a0a] via-transparent to-transparent z-10"></div>
                <img
                  src={project.image}
                  alt={`Screenshot do projeto ${project.title} - ${project.description.substring(0, 60)}`}
                  width="400"
                  height="176"
                  loading="lazy"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
                  onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22300%22%3E%3Crect fill=%22%23111%22 width=%22400%22 height=%22300%22/%3E%3Ctext fill=%22%23444%22 x=%2250%25%22 y=%2250%25%22 text-anchor=%22middle%22 font-family=%22monospace%22 dy=%22.3em%22%3EProjeto%3C/text%3E%3C/svg%3E'"
                />
              </div>
              <div class="p-6">
                <h3 class="text-lg font-bold text-white mb-2">{project.title}</h3>
                <p class="text-secondary text-sm mb-5 leading-relaxed">{project.description}</p>
                <div class="flex flex-wrap gap-2 mb-6">
                  {project.technologies.slice(0, 3).map((tech) => (
                    <span class="portfolio-tech-tag text-[11px]">{tech}</span>
                  ))}
                </div>
                <a
                  href={project.link}
                  target="_blank"
                  class="btn-outline inline-flex items-center gap-2 px-5 py-2.5 text-white text-sm font-medium"
                >
                  Ver Projeto
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="animate-on-scroll" style="margin-top: 8rem;">
        <div class="cta-led-wrapper max-w-4xl mx-auto">
          <div class="cta-led-border">
            <div class="cta-led-content text-center" style="padding: 4rem 5rem;">
              <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4">
                Quer desenvolver um projeto como esses?
              </h2>
              <p class="text-secondary mb-10 max-w-xl mx-auto">
                Na Made In Vibe Coding voce aprende a construir aplicacoes reais com as melhores praticas do mercado.
              </p>
              <a href="#planos" class="btn-primary inline-flex items-center gap-2 px-8 py-4 text-white font-semibold">
                Comecar Agora
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .portfolio-featured-card {
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .portfolio-featured-card:hover {
    border-color: rgba(255, 107, 0, 0.3);
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 107, 0, 0.1);
    transform: translateY(-4px);
  }

  .portfolio-card {
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.06);
    overflow: hidden;
    transition: all 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .portfolio-card:hover {
    border-color: rgba(255, 107, 0, 0.25);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.4);
    transform: translateY(-3px);
  }

  .portfolio-tech-tag {
    padding: 4px 10px;
    font-size: 11px;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500;
    color: #888;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.2s ease;
  }

  .portfolio-card:hover .portfolio-tech-tag,
  .portfolio-featured-card:hover .portfolio-tech-tag {
    border-color: rgba(255, 107, 0, 0.15);
    color: #aaa;
  }

  /* CTA LED border effect */
  @property --led-angle {
    syntax: '<angle>';
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes led-rotate {
    0% { --led-angle: 0deg; }
    100% { --led-angle: 360deg; }
  }

  .cta-led-wrapper {
    position: relative;
  }

  .cta-led-border {
    position: relative;
    padding: 2px;
    background: conic-gradient(
      from var(--led-angle),
      transparent 0%,
      transparent 55%,
      #FF6B00 70%,
      #FF8C3A 75%,
      #FFAA55 78%,
      #FF8C3A 81%,
      #FF6B00 86%,
      transparent 95%,
      transparent 100%
    );
    animation: led-rotate 3s linear infinite;
  }

  .cta-led-border::before {
    content: '';
    position: absolute;
    inset: 0;
    padding: 2px;
    background: conic-gradient(
      from var(--led-angle),
      transparent 0%,
      transparent 55%,
      #FF6B00 70%,
      #FF8C3A 75%,
      #FFAA55 78%,
      #FF8C3A 81%,
      #FF6B00 86%,
      transparent 95%,
      transparent 100%
    );
    filter: blur(12px);
    opacity: 0.6;
    z-index: -1;
    animation: led-rotate 3s linear infinite;
  }

  .cta-led-content {
    position: relative;
    z-index: 1;
    background: #0a0a0a;
  }

  .portfolio-back-link:hover svg {
    transform: translateX(-3px);
    transition: transform 0.2s ease;
  }

  .portfolio-back-link svg {
    transition: transform 0.2s ease;
  }
</style>
